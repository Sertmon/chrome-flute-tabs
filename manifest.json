{
  "manifest_version": 3,
  "name": "Флейта — табы",
  "description": "Слушает микрофон, записывает ноты и показывает аппликатуру блокфлейты сопрано в C.",
  "version": "1.0.2",
  "minimum_chrome_version": "116",
  "permissions": [
    "sidePanel",
    "tabs"
  ],
  "action": {
    "default_title": "Флейта — табы"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
