{
  "manifest_version": 3,
  "name": "Флейта — табы",
  "description": "Слушает микрофон или звук вкладки, записывает ноты и показывает аппликатуру блокфлейты.",
  "version": "1.7.1",
  "minimum_chrome_version": "116",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "tabCapture"
  ],
  "action": {
    "default_title": "Флейта — табы"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
